<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - Bank Management System</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }

        .login-container {
            background: white;
            border-radius: 15px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
            max-width: 450px;
            width: 100%;
            overflow: hidden;
        }

        .header {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 40px 30px;
            text-align: center;
        }

        .header h1 {
            font-size: 2em;
            margin-bottom: 10px;
        }

        .header p {
            font-size: 0.95em;
            opacity: 0.9;
        }

        .form-content {
            padding: 40px 30px;
        }

        .form-group {
            margin-bottom: 25px;
        }

        .form-group label {
            display: block;
            margin-bottom: 10px;
            color: #333;
            font-weight: 600;
            font-size: 0.95em;
        }

        .role-selection {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 15px;
            margin-bottom: 30px;
        }

        .role-option {
            position: relative;
        }

        .role-option input[type="radio"] {
            display: none;
        }

        .role-label {
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 15px;
            border: 2px solid #e0e0e0;
            border-radius: 8px;
            cursor: pointer;
            transition: all 0.3s ease;
            font-weight: 600;
            background: #f8f9fa;
            color: #333;
        }

        .role-option input[type="radio"]:checked + .role-label {
            border-color: #667eea;
            background: #667eea;
            color: white;
            box-shadow: 0 4px 12px rgba(102, 126, 234, 0.3);
        }

        .role-label:hover {
            border-color: #667eea;
            background: #f0f2ff;
        }

        .role-option input[type="radio"]:checked + .role-label:hover {
            background: #667eea;
        }

        .role-icon {
            font-size: 1.3em;
            margin-right: 8px;
        }

        .input-group {
            display: none;
        }

        .input-group.active {
            display: block;
            animation: fadeIn 0.3s ease;
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(-10px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .input-field {
            width: 100%;
            padding: 12px 15px;
            border: 2px solid #e0e0e0;
            border-radius: 8px;
            font-size: 0.95em;
            transition: all 0.3s ease;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        .input-field:focus {
            outline: none;
            border-color: #667eea;
            box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
            background-color: #f8f9ff;
        }

        .input-field::placeholder {
            color: #999;
        }

        .form-group.two-columns {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 15px;
        }

        .form-group.two-columns .form-group {
            margin-bottom: 0;
        }

        .remember-forgot {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 25px;
            font-size: 0.9em;
        }

        .remember-me {
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .remember-me input[type="checkbox"] {
            width: 18px;
            height: 18px;
            cursor: pointer;
            accent-color: #667eea;
        }

        .remember-me label {
            margin: 0;
            cursor: pointer;
            color: #555;
            font-weight: 400;
        }

        .forgot-password {
            color: #667eea;
            text-decoration: none;
            font-weight: 500;
            transition: color 0.3s ease;
        }

        .forgot-password:hover {
            color: #764ba2;
            text-decoration: underline;
        }

        .login-button {
            width: 100%;
            padding: 13px 20px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            border: none;
            border-radius: 8px;
            font-size: 1em;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            box-shadow: 0 4px 12px rgba(102, 126, 234, 0.3);
        }

        .login-button:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 16px rgba(102, 126, 234, 0.4);
        }

        .login-button:active {
            transform: translateY(0);
        }

        .signup-link {
            text-align: center;
            margin-top: 25px;
            padding-top: 25px;
            border-top: 1px solid #e0e0e0;
            color: #666;
            font-size: 0.9em;
        }

        .signup-link a {
            color: #667eea;
            text-decoration: none;
            font-weight: 600;
            transition: color 0.3s ease;
        }

        .signup-link a:hover {
            color: #764ba2;
            text-decoration: underline;
        }

        .error-message {
            color: #d32f2f;
            font-size: 0.85em;
            margin-top: 5px;
            display: none;
        }

        .form-group.error .input-field {
            border-color: #d32f2f;
            background-color: #ffebee;
        }

        .form-group.error .error-message {
            display: block;
        }

        .success-message {
            background-color: #e8f5e9;
            border-left: 4px solid #4caf50;
            color: #2e7d32;
            padding: 12px 15px;
            border-radius: 4px;
            margin-bottom: 20px;
            display: none;
            font-size: 0.9em;
        }

        @media (max-width: 480px) {
            .login-container {
                box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
            }

            .header {
                padding: 30px 20px;
            }

            .header h1 {
                font-size: 1.5em;
            }

            .form-content {
                padding: 30px 20px;
            }

            .role-selection {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>
    <div class="login-container">
        <div class="header">
            <h1>🏦 Bank Login</h1>
            <p>Secure Access to Your Account</p>
        </div>

        <div class="form-content">
            <div class="success-message" id="successMessage">
                Login successfully! Redirecting...
            </div>

            <form id="loginForm" method="POST" action="/auth/login">
                <!-- Role Selection -->
                <div class="form-group">
                    <label>Select Login Type</label>
                    <div class="role-selection">
                        <div class="role-option">
                            <input type="radio" id="hostRole" name="role" value="host" required>
                            <label for="hostRole" class="role-label">
                                <span class="role-icon">🏦</span>
                                Host
                            </label>
                        </div>
                        <div class="role-option">
                            <input type="radio" id="userRole" name="role" value="user" required>
                            <label for="userRole" class="role-label">
                                <span class="role-icon">👤</span>
                                User
                            </label>
                        </div>
                    </div>
                </div>

                <!-- Host Login Fields -->
                <div class="input-group" id="hostFields">
                    <div class="form-group">
                        <label for="hostId">Host ID</label>
                        <input 
                            type="text" 
                            id="hostId" 
                            name="hostId" 
                            class="input-field" 
                            placeholder="Enter your Host ID"
                            pattern="[A-Za-z0-9]{6,20}"
                            title="Host ID must be 6-20 alphanumeric characters"
                        >
                        <div class="error-message">Please enter a valid Host ID</div>
                    </div>

                    <div class="form-group">
                        <label for="hostPassword">Password</label>
                        <input 
                            type="password" 
                            id="hostPassword" 
                            name="hostPassword" 
                            class="input-field" 
                            placeholder="Enter your password"
                            minlength="6"
                        >
                        <div class="error-message">Password is required</div>
                    </div>
                </div>

                <!-- User Login Fields -->
                <div class="input-group" id="userFields">
                    <div class="form-group">
                        <label for="accountNumber">Account Number</label>
                        <input 
                            type="text" 
                            id="accountNumber" 
                            name="accountNumber" 
                            class="input-field" 
                            placeholder="Enter your Account Number"
                            pattern="[0-9]{9,18}"
                            title="Account number should be 9-18 digits"
                        >
                        <div class="error-message">Please enter a valid Account Number</div>
                    </div>

                    <div class="form-group.two-columns">
                        <div class="form-group">
                            <label for="ifscCode">IFSC Code</label>
                            <input 
                                type="text" 
                                id="ifscCode" 
                                name="ifscCode" 
                                class="input-field" 
                                placeholder="e.g., SBIN0001234"
                                pattern="[A-Z]{4}0[A-Z0-9]{6}"
                                title="IFSC code format: 4 letters, 0, then 6 alphanumeric characters"
                                style="text-transform: uppercase;"
                            >
                            <div class="error-message">Please enter a valid IFSC code</div>
                        </div>
                    </div>

                    <div class="form-group">
                        <label for="userPassword">Password</label>
                        <input 
                            type="password" 
                            id="userPassword" 
                            name="userPassword" 
                            class="input-field" 
                            placeholder="Enter your password"
                            minlength="6"
                        >
                        <div class="error-message">Password is required</div>
                    </div>
                </div>

                <!-- Remember & Forgot -->
                <div class="remember-forgot">
                    <div class="remember-me">
                        <input type="checkbox" id="rememberMe" name="rememberMe">
                        <label for="rememberMe">Remember me</label>
                    </div>
                    <a href="#" class="forgot-password">Forgot Password?</a>
                </div>

                <!-- Login Button -->
                <button type="submit" class="login-button">Login</button>

                <!-- Sign Up Link -->
                <div class="signup-link">
                    Don't have an account? <a href="/signup">Sign up here</a>
                </div>
            </form>
        </div>
    </div>

    <script>
        const loginForm = document.getElementById('loginForm');
        const hostRole = document.getElementById('hostRole');
        const userRole = document.getElementById('userRole');
        const hostFields = document.getElementById('hostFields');
        const userFields = document.getElementById('userFields');
        const successMessage = document.getElementById('successMessage');

        // Update role selection
        hostRole.addEventListener('change', updateLoginFields);
        userRole.addEventListener('change', updateLoginFields);

        function updateLoginFields() {
            if (hostRole.checked) {
                hostFields.classList.add('active');
                userFields.classList.remove('active');
                
                // Remove required from user fields
                document.getElementById('accountNumber').removeAttribute('required');
                document.getElementById('ifscCode').removeAttribute('required');
                document.getElementById('userPassword').removeAttribute('required');
                
                // Add required to host fields
                document.getElementById('hostId').setAttribute('required', 'required');
                document.getElementById('hostPassword').setAttribute('required', 'required');
            } else if (userRole.checked) {
                userFields.classList.add('active');
                hostFields.classList.remove('active');
                
                // Remove required from host fields
                document.getElementById('hostId').removeAttribute('required');
                document.getElementById('hostPassword').removeAttribute('required');
                
                // Add required to user fields
                document.getElementById('accountNumber').setAttribute('required', 'required');
                document.getElementById('ifscCode').setAttribute('required', 'required');
                document.getElementById('userPassword').setAttribute('required', 'required');
            }
        }

        // Form submission
        loginForm.addEventListener('submit', function(e) {
            e.preventDefault();
            
            // Validate role selection
            if (!hostRole.checked && !userRole.checked) {
                alert('Please select a login type!');
                return;
            }

            // Validate selected role fields
            let isValid = true;
            
            if (hostRole.checked) {
                const hostId = document.getElementById('hostId').value.trim();
                const hostPassword = document.getElementById('hostPassword').value;
                
                if (!hostId || hostId.length < 6) {
                    showError('hostId', 'Host ID must be at least 6 characters');
                    isValid = false;
                }
                if (!hostPassword || hostPassword.length < 6) {
                    showError('hostPassword', 'Password must be at least 6 characters');
                    isValid = false;
                }
            } else if (userRole.checked) {
                const accountNumber = document.getElementById('accountNumber').value.trim();
                const ifscCode = document.getElementById('ifscCode').value.trim().toUpperCase();
                const userPassword = document.getElementById('userPassword').value;
                
                if (!accountNumber || accountNumber.length < 9) {
                    showError('accountNumber', 'Account number must be at least 9 digits');
                    isValid = false;
                }
                const ifscRegex = /^[A-Z]{4}0[A-Z0-9]{6}$/;
                if (!ifscCode || !ifscRegex.test(ifscCode)) {
                    showError('ifscCode', 'IFSC code format is invalid');
                    isValid = false;
                }
                if (!userPassword || userPassword.length < 6) {
                    showError('userPassword', 'Password must be at least 6 characters');
                    isValid = false;
                }
            }

            if (!isValid) {
                return;
            }

            // If validation passes, show success message and submit
            successMessage.style.display = 'block';
            
            // Submit form after a short delay
            setTimeout(() => {
                loginForm.submit();
            }, 1500);
        });

        function showError(fieldId, message) {
            const field = document.getElementById(fieldId);
            const formGroup = field.closest('.form-group');
            formGroup.classList.add('error');
            formGroup.querySelector('.error-message').textContent = message;
        }

        // Clear error on input
        const inputFields = document.querySelectorAll('.input-field');
        inputFields.forEach(field => {
            field.addEventListener('input', function() {
                const formGroup = this.closest('.form-group');
                formGroup.classList.remove('error');
            });
        });

        // Auto-format IFSC code to uppercase
        document.getElementById('ifscCode').addEventListener('input', function() {
            this.value = this.value.toUpperCase();
        });
    </script>
</body>
</html>
